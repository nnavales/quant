# ============================================================
# SUMMIT - .gitignore
# ============================================================

# --- Build outputs ---
bin/
tmp/
./data/
app/dist/
app/src-tauri/target/
app/src-tauri/binaries/

# --- Package managers ---
node_modules/
app/node_modules/

# --- Python ---
.venv/
__pycache__/
*.pyc

# --- Linters / formatters ---
.ruff_cache/

# --- Databases ---
*.db
*.sqlite
*.sqlite3

# --- Environment / secrets ---
.env
.env*.local
app/.env

# --- macOS ---
.DS_Store
*.pem

# --- Logs / debug ---
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# --- TypeScript ---
*.tsbuildinfo

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
steps.md

# --- OS artifacts ---
*.orig.*
Thumbs.db

# --- Project-specific (do not track) ---
AGENTS.md
justfile
app-example

# --- Expo / React Native (legacy, kept for safety) ---
.expo/
web-build/
expo-env.d.ts
.kotlin/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
.metro-health-check*
/ios
/android
